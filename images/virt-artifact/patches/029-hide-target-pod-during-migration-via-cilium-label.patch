+type NetworkAccessibilityManager struct {
+	virtClient kubecli.KubevirtClient
+}
+
+func (m NetworkAccessibilityManager) Disable(pod *k8sv1.Pod) error {
+	if pod == nil {
+		return errors.New("got nil pod to disable network accessibility")
+	}
+
+	// 1. Do nothing if its accessibility is already disabled.
+	if _, exists := pod.Labels[virtv1.HiddenMigrationPodLabel]; exists {
+		return nil
+	}
+
+	// 2. Add special label to the pod to make it not accessible via network.
+	patchSet := patch.New(
+		patch.WithTest(fmt.Sprintf("/metadata/labels/%s", patch.EscapeJSONPointer(virtv1.HiddenMigrationPodLabel)), nil),
+		patch.WithAdd(fmt.Sprintf("/metadata/labels/%s", patch.EscapeJSONPointer(virtv1.HiddenMigrationPodLabel)), ""),
+	)
+	patchBytes, err := patchSet.GeneratePayload()
+	if err != nil {
+		return fmt.Errorf("generate patch: %w", err)
+	}
+
+	_, err = m.virtClient.CoreV1().Pods(pod.Namespace).Patch(context.Background(), pod.Name, types.JSONPatchType, patchBytes, v1.PatchOptions{})
+	if err != nil {
+		return fmt.Errorf("apply patch to add pod label %s: %w", virtv1.HiddenMigrationPodLabel, err)
+	}
+
+	return nil
+}
+
+func (m NetworkAccessibilityManager) Enable(pod *k8sv1.Pod) error {
+	if pod == nil {
+		return errors.New("got nil pod to enable network accessibility")
+	}
+
+	// 1. Do nothing if its accessibility is already enabled.
+	if _, exists := pod.Labels[virtv1.HiddenMigrationPodLabel]; !exists {
+		return nil
+	}
+
+	// 2. Remove special label from the pod to make it accessible via network.
+	patchSet := patch.New(
+		patch.WithTest(fmt.Sprintf("/metadata/labels/%s", patch.EscapeJSONPointer(virtv1.HiddenMigrationPodLabel)), ""),
+		patch.WithRemove(fmt.Sprintf("/metadata/labels/%s", patch.EscapeJSONPointer(virtv1.HiddenMigrationPodLabel))),
+	)
+	patchBytes, err := patchSet.GeneratePayload()
+	if err != nil {
+		return fmt.Errorf("generate patch: %w", err)
+	}
+
+	_, err = m.virtClient.CoreV1().Pods(pod.Namespace).Patch(context.Background(), pod.Name, types.JSONPatchType, patchBytes, v1.PatchOptions{})
+	if err != nil {
+		return fmt.Errorf("apply patch to remove pod label %s: %w", virtv1.HiddenMigrationPodLabel, err)
+	}
+
+	return nil
+}
+
+func (c *MigrationController) findSourcePod(migration *virtv1.VirtualMachineInstanceMigration) (*k8sv1.Pod, error) {
+	if migration.Status.MigrationState == nil || migration.Status.MigrationState.SourcePod == "" {
+		return nil, fmt.Errorf("the migration %s/%s doesn't have the source pod name", migration.Namespace, migration.Name)
+	}
+
+	objs, err := c.podIndexer.ByIndex(cache.NamespaceIndex, migration.Namespace)
+	if err != nil {
+		return nil, fmt.Errorf("get pods by namespace %s: %w", migration.Namespace, err)
+	}
+
+	for _, obj := range objs {
+		pod := obj.(*k8sv1.Pod)
+		if pod.Name == migration.Status.MigrationState.SourcePod {
+			return pod, nil
+		}
+	}
+
+	return nil, nil
+}
