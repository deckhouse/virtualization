+func (c *VMController) setStartAnnotationOnVm(vm *virtv1.VirtualMachine) error {
+	anno := "kubevirt.io/vm-start-requested"
+
+	if vm.Annotations[anno] != "true" {
+		patchset := patch.New()
+		patchset.AddOption(patch.WithAdd(fmt.Sprintf("/metadata/annotations/%s", anno), "true"))
+		generatedPatch, err := patchset.GeneratePayload()
+		if err != nil {
+			return err
+		}
+		_, err = c.clientset.VirtualMachineInstance(vm.Namespace).Patch(context.Background(), vm.Name, types.JSONPatchType, generatedPatch, metav1.PatchOptions{})
+		if err != nil {
+			return err
+		}
+	}
+	return nil
+}
