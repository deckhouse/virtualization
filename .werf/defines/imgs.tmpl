{{/* Helpers for generate images name with or without ModuleName

Usage:
{{ include "ImageName" (list . "bins") }} cdi-artifact-bins
{{ include "ImageName" (list . ) }} - cdi-artifact
{{ include "ImageName" (list . "bins") }} - .virtualization/cdi-artifact-bins
*/}}

{{ define "ImageName" }}
{{- $defineCtx := . -}}
{{- $ImageNameSuffix := "" -}}

{{-   if (kindIs "slice" .) -}}
{{-     $defineCtx = index . 0 -}}
{{-     if ge (len .) 2 -}}
{{-       $ImageNameSuffix = index . 1 -}}
{{-     end -}}
{{-   end -}}

{{- include "ModuleNamePreffix" $defineCtx -}}
{{- $defineCtx.ImageName -}}
{{- if $ImageNameSuffix }}-{{ $ImageNameSuffix }}{{ end -}}

{{ end }}


{{ define "ModuleNamePreffix" }}
{{- if .ModuleName }}{{ .ModuleName }}/{{ end -}}
{{ end }}
